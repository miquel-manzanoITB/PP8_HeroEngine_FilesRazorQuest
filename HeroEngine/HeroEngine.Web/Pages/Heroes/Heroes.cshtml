@page
@model HeroesModel
@{
    ViewData["Title"] = "Heroes";
}

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
    <h1 style="margin-bottom:0;">Heroes of Bytecroft</h1>
    <a asp-page="/Heroes/Create" class="btn btn-primary">+ New hero</a>
</div>

@if (!Model.Heroes.Any())
{
    <div class="card" style="text-align:center; padding:3rem;">
        <p style="color:#7070a0; margin-bottom:1rem;">No heroes registered yet.</p>
        <a asp-page="/Heroes/Create" class="btn btn-primary">Create your first hero</a>
    </div>
}
else
{
    <div class="card" style="padding:0; overflow:hidden;">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Class</th>
                    <th>Level</th>
                    <th>Max HP</th>
                    <th>Armor</th>
                    <th>Abilities</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in Model.Heroes)
                {
                    <tr>
                        <td>
                            <a asp-page="/Heroes/Detail" asp-route-name="@h.Name"
                                   style="color:#c0b0ff; text-decoration:none; font-weight:500;">
                                @h.Name
                            </a>
                        </td>
                        <td><span class="badge badge-@h.Type.ToLower()">@h.Type</span></td>
                        <td>@h.Level</td>
                        <td>@h.MaxHp</td>
                        <td>@(h.Armor > 0 ? h.Armor.ToString() : "—")</td>
                        <td>@h.Abilities.Count</td>
                        <td>
                            <a asp-page="/Heroes/Detail" asp-route-name="@h.Name"
                                   class="btn btn-secondary" style="padding:4px 10px; font-size:0.8rem;">
                                Detail
                            </a>
                            <form method="post" asp-page-handler="Delete" style="display:inline;"
                                  onsubmit="return confirm('Delete @h.Name?');">
                                <input type="hidden" name="name" value="@h.Name" />
                                <button type="submit" class="btn btn-danger"
                                        style="padding:4px 10px; font-size:0.8rem;">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
