@page
@model FilesPageModel
@{
    ViewData["Title"] = "Files";
}

<h1>📁 File Management</h1>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert @(Model.IsError ? "alert-danger" : "alert-success")">@Model.Message</div>
}

<div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">

    <!-- Game config XML -->
    <div class="card">
        <h2>Game config (game_config.xml)</h2>
        <form method="post" asp-page-handler="SaveConfig">
            <div class="form-group">
                <label asp-for="Config.LevelMultiplier">Level multiplier</label>
                <input asp-for="Config.LevelMultiplier" type="number" step="0.01" />
            </div>
            <div class="form-group">
                <label asp-for="Config.CriticalHitChance">Critical hit chance (0.0–1.0)</label>
                <input asp-for="Config.CriticalHitChance" type="number" step="0.01" min="0" max="1" />
            </div>
            <div class="form-group">
                <label asp-for="Config.MaxCombatRounds">Max combat rounds</label>
                <input asp-for="Config.MaxCombatRounds" type="number" min="1" />
            </div>
            <div class="form-group">
                <label asp-for="Config.MaxHeroesPerBattle">Max heroes per battle</label>
                <input asp-for="Config.MaxHeroesPerBattle" type="number" min="1" max="10" />
            </div>
            <button type="submit" class="btn btn-primary">Save config</button>
        </form>
    </div>

    <!-- CSV stats table -->
    <div class="card">
        <h2>Combat stats (combat_stats.csv)</h2>
        <form method="post" asp-page-handler="DownloadCsv" style="margin-bottom:1rem;">
            <button type="submit" class="btn btn-secondary">⬇ Download CSV</button>
        </form>

        @if (!Model.CombatRows.Any())
        {
            <p style="color:#7070a0; font-size:0.9rem;">No combat data yet.</p>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table style="font-size:0.8rem;">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Heroes</th>
                            <th>Enemies</th>
                            <th>Result</th>
                            <th>Rounds</th>
                            <th>Dmg</th>
                            <th>MVP</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.CombatRows)
                        {
                            <tr>
                                @for (int i = 0; i < row.Length; i++)
                                {
                                    <td>
                                        @if (i == 3)
                                        {
                                            <span class="badge @(row[i].Contains("Victory") ? "badge-victory" : "badge-defeat")">
                                                @row[i]
                                            </span>
                                        }
                                        else
                                        {
                                            @row[i]
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Heroes JSON export/import -->
<div class="card">
    <h2>Heroes JSON (heroes.json)</h2>
    <div style="display:flex; gap:10px; margin-bottom:1rem;">
        <form method="post" asp-page-handler="DownloadJson">
            <button type="submit" class="btn btn-secondary">⬇ Download heroes.json</button>
        </form>
    </div>
    <pre style="max-height:250px;">@Model.HeroesJson</pre>
</div>

<!-- Raw XML config -->
<div class="card">
    <h2>Raw game_config.xml</h2>
    <pre style="max-height:200px;">@Model.ConfigXml</pre>
</div>
